    {
        "id": "d543d624a90b9781",
        "type": "function",
        "z": "fb2d99fb28f6bd92",
        "name": "Format to CSV rows",
        "func": "var d = msg.payload;\nvar sd = d.sensor_data;\n\n// Full resolution timestamp split into date + time with milliseconds\nvar now = new Date();\nvar date = now.getFullYear() + '-' +\n           String(now.getMonth() + 1).padStart(2, '0') + '-' +\n           String(now.getDate()).padStart(2, '0');\nvar time_ms = String(now.getHours()).padStart(2, '0') + ':' +\n              String(now.getMinutes()).padStart(2, '0') + ':' +\n              String(now.getSeconds()).padStart(2, '0') + '.' +\n              String(now.getMilliseconds()).padStart(3, '0');\n\nvar headerWritten = flow.get('csvHeaderWritten') || false;\nvar rows = '';\n\nif (!headerWritten) {\n    rows = 'date,time_ms,addr,battery_percent,temperature_c,odr_hz,fft_confidence,sample_index,x_g,y_g,z_g\\n';\n    flow.set('csvHeaderWritten', true);\n}\n\nvar xData = sd.data.x;\nvar yData = sd.data.y;\nvar zData = sd.data.z;\nvar temp = (sd.device_temp !== undefined) ? sd.device_temp : (sd.temperature !== undefined ? sd.temperature : '');\nvar odr = sd.odr || '';\nvar fft = sd.fft_confidence || '';\n\nfor (var i = 0; i < xData.length; i++) {\n    rows += date + ',' +\n            time_ms + ',' +\n            d.addr + ',' +\n            d.battery_percent + ',' +\n            temp + ',' +\n            odr + ',' +\n            fft + ',' +\n            i + ',' +\n            xData[i] + ',' +\n            yData[i] + ',' +\n            zData[i] + '\\n';\n}\n\nmsg.payload = rows;\nmsg.filename = 'C:\\\\Users\\\\Ukesh Marshal\\\\Downloads\\\\vibration_data.csv';\nmsg.flags = { append: true };\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
