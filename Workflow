    {
        "id": "a848f0ea372974ec",
        "type": "function",
        "z": "fb2d99fb28f6bd92",
        "name": "⚙️ Config Status",
        "func": "var topic = msg.topic || '';\nvar payload = msg.payload || {};\nvar mode = payload.mode || '';\n\n// ── Sensor mode messages ──────────────────────────────────\nif (topic === 'sensor_mode') {\n    if (mode === 'RUN') {\n        node.status({fill:'green', shape:'dot', text:'🟢 RUNNING — sensor awake & transmitting'});\n        node.warn('🟢 RUN: Sensor is awake and transmitting normally');\n    }\n    else if (mode === 'FLY') {\n        node.status({fill:'blue', shape:'ring', text:'🔵 FLY — checking for config updates...'});\n        node.warn('🔵 FLY: Sensor checking in — Node-RED has 2 seconds to push config');\n    }\n    else if (mode === 'PGM') {\n        node.status({fill:'yellow', shape:'ring', text:'🟡 CONFIG MODE — sensor ready to receive settings'});\n        node.warn('🟡 PGM: Sensor is in manual configuration mode');\n    }\n    else if (mode === 'ACK') {\n        node.status({fill:'blue', shape:'dot', text:'📨 ACK — parameter received by sensor'});\n        node.warn('📨 ACK: Sensor acknowledged a configuration command');\n    }\n    else if (mode === 'PUM') {\n        node.status({fill:'grey', shape:'ring', text:'🔄 FACTORY RESET — sensor reverted to defaults'});\n        node.warn('🔄 PUM: Sensor was factory reset. Configure and reset to resume.');\n    }\n    else if (mode === 'MOFF') {\n        node.status({fill:'grey', shape:'dot', text:'⚫ MOTOR OFF — machine not running'});\n        node.warn('⚫ MOFF: Sensor says machine is OFF (vibration below threshold)');\n    }\n    else if (mode === 'UPTHWRN') {\n        node.status({fill:'red', shape:'ring', text:'⚠️ THRESHOLD WARNING — triggering too often, battery drain risk'});\n        node.warn('⚠️ UPTHWRN: Smart threshold too low — sensor triggering constantly. Raise threshold to protect battery.');\n    }\n}\n\n// ── Config Results message ────────────────────────────────\nelse if (topic === 'Config Results') {\n    var p = payload;\n    var allOk = true;\n    var results = [];\n\n    // Check each key that ends in known param patterns\n    for (var key in p) {\n        if (key === 'addr' || key === 'time' || key === '_msgid') continue;\n        if (typeof p[key] === 'boolean') {\n            results.push((p[key] ? '✅' : '❌') + ' ' + key + ': ' + p[key]);\n            if (!p[key]) allOk = false;\n        }\n    }\n\n    if (allOk) {\n        node.status({fill:'green', shape:'dot', text:'✅ CONFIG COMPLETE — all settings written to sensor'});\n        node.warn('✅ CONFIG COMPLETE:\\n' + results.join('\\n'));\n    } else {\n        node.status({fill:'red', shape:'dot', text:'❌ CONFIG PARTIAL — some settings failed, check log'});\n        node.warn('❌ CONFIG PARTIAL — some parameters failed:\\n' + results.join('\\n'));\n    }\n}\n\n// ── OTN Request Results ───────────────────────────────────\nelse if (topic === 'OTN Request Results') {\n    node.status({fill:'blue', shape:'ring', text:'🔵 OTN — config window extended to 60 seconds'});\n    node.warn('🔵 OTN: Config window extended. Pushing parameters now...');\n}\n\n// ── Sensor data (running confirmation) ───────────────────\nelse if (topic === 'sensor_data') {\n    var sd = payload.sensor_data || {};\n    var modeNum = sd.mode;\n    var modeLabel = modeNum === 0 ? 'Processed' : modeNum === 1 ? 'Raw' : modeNum === 2 ? 'On Demand' : modeNum === 3 ? 'Smart' : 'Unknown';\n    node.status({fill:'green', shape:'dot', text:'📡 DATA: mode=' + modeLabel + ' | ODR=' + (sd.odr||'?') + ' | fft=' + (sd.fft_confidence||'?')});\n}\n\nreturn msg;",
